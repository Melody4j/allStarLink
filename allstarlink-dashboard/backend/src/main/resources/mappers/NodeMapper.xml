<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.allstarlink.dashboard.mapper.NodeMapper">

    <!-- 结果映射 -->
    <resultMap id="NodeResultMap" type="com.allstarlink.dashboard.entity.Node">
        <id property="id" column="id" />
        <result property="nodeId" column="node_id" />
        <result property="owner" column="owner" />
        <result property="callsign" column="callsign" />
        <result property="frequency" column="frequency" />
        <result property="tone" column="tone" />
        <result property="location" column="location" />
        <result property="site" column="site" />
        <result property="affiliation" column="affiliation" />
        <result property="lastSeen" column="last_seen" />
        <result property="features" column="features" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
        <result property="latitude" column="latitude" />
        <result property="longitude" column="longitude" />
        <result property="isActive" column="is_active" />
    </resultMap>

    <!-- 获取所有节点 -->
    <select id="selectAll" resultMap="NodeResultMap">
        SELECT * FROM nodes
        WHERE created_at > (
            SELECT DATE_SUB(MAX(created_at), INTERVAL 2 MINUTE) FROM nodes
        )
        ORDER BY created_at DESC
    </select>

    <!-- 根据节点ID获取节点 -->
    <select id="selectByNodeId" resultMap="NodeResultMap">
        SELECT * FROM nodes WHERE node_id = #{nodeId}
    </select>

    <!-- 获取所有活跃节点 -->
    <select id="selectActiveNodes" resultMap="NodeResultMap">
        SELECT * FROM nodes WHERE is_active = 1
        AND created_at > (
            SELECT DATE_SUB(MAX(created_at), INTERVAL 2 MINUTE) FROM nodes
        )
        ORDER BY created_at DESC
    </select>

    <!-- 根据地理范围查询节点 -->
    <select id="selectNodesByGeoBounds" resultMap="NodeResultMap">
        SELECT * FROM nodes 
        WHERE latitude BETWEEN #{minLat} AND #{maxLat} 
        AND longitude BETWEEN #{minLon} AND #{maxLon}
        AND created_at > (
            SELECT DATE_SUB(MAX(created_at), INTERVAL 2 MINUTE) FROM nodes
        )
        ORDER BY created_at DESC
    </select>

    <!-- 获取节点总数 -->
    <select id="count" resultType="long">
        SELECT COUNT(*) FROM nodes
        WHERE created_at > (
            SELECT DATE_SUB(MAX(created_at), INTERVAL 2 MINUTE) FROM nodes
        )
    </select>

    <!-- 获取活跃节点数 -->
    <select id="countActiveNodes" resultType="long">
        SELECT COUNT(*) FROM nodes WHERE is_active = 1
        AND created_at > (
            SELECT DATE_SUB(MAX(created_at), INTERVAL 2 MINUTE) FROM nodes
        )
    </select>

</mapper>