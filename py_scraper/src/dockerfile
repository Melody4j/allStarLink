# 使用Python 3.9作为基础镜像
FROM python:3.9-slim

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# 使用阿里云镜像源
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list && \
    sed -i 's/security.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list

# 安装系统依赖（添加重试机制）
RUN apt-get update --fix-missing && \
    apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# 使用阿里云pip镜像源
RUN pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/

# 复制requirements.txt
COPY requirements.txt .

# 安装Python依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制项目代码
COPY . .

# 设置日志级别（可通过环境变量覆盖）
ENV LOG_LEVEL=INFO

# 设置爬取参数默认值（可通过环境变量覆盖）
ENV RATE_LIMIT=60
ENV DELAY_MAX=1
ENV DELAY_MIN=0.8
ENV COOLDOWN=30

# 暴露端口（如果需要）
# EXPOSE 8000

# 创建启动脚本
RUN echo '#!/bin/bash' > /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '# 从环境变量读取参数，如果设置了则作为命令行参数传递' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'ARGS=""' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'if [ -n "$RATE_LIMIT" ]; then' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '    ARGS="$ARGS $RATE_LIMIT"' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'fi' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'if [ -n "$DELAY_MAX" ]; then' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '    ARGS="$ARGS $DELAY_MAX"' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'fi' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'if [ -n "$DELAY_MIN" ]; then' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '    ARGS="$ARGS $DELAY_MIN"' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'fi' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'if [ -n "$COOLDOWN" ]; then' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '    ARGS="$ARGS $COOLDOWN"' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'fi' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '' >> /usr/local/bin/docker-entrypoint.sh && \
    echo '# 执行命令，将参数传递给主程序' >> /usr/local/bin/docker-entrypoint.sh && \
    echo 'exec "$@" $ARGS' >> /usr/local/bin/docker-entrypoint.sh && \
    chmod +x /usr/local/bin/docker-entrypoint.sh

# 运行程序
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["python", "-m", "link_scraper.main"]
